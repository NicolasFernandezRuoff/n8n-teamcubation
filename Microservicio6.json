        "jsonSchemaExample": "{\n  \"titulo\": \"Tema Investigado\",\n  \"introduccion\": \"Párrafo introductorio...\",\n  \"puntos_clave\": [\n    {\n      \"subtitulo\": \"Concepto 1\",\n      \"explicacion\": \"Detalle profundo...\"\n    }\n  ],\n  \"conclusion\": \"Resumen final...\"\n}"
      },

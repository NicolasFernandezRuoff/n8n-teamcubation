    {
      "parameters": {
        "jsCode": "const data = $input.first().json.output;\nlet html = `\n<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <style>\n        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; padding: 40px; color: #2C3E50; line-height: 1.6; }\n        .header { border-bottom: 3px solid #2980B9; padding-bottom: 20px; margin-bottom: 30px; }\n        h1 { margin: 0; font-size: 28px; color: #2980B9; text-transform: uppercase; }\n        h2 { color: #34495E; border-bottom: 1px solid #ECF0F1; padding-bottom: 5px; margin-top: 30px; }\n        .intro { font-size: 16px; font-style: italic; color: #7F8C8D; margin-bottom: 30px; background: #F8F9FA; padding: 15px; border-left: 4px solid #BDC3C7; }\n        .punto { margin-bottom: 20px; }\n        .subtitulo { font-weight: bold; font-size: 18px; color: #2C3E50; margin-bottom: 5px; }\n        .explicacion { margin-left: 15px; }\n        .conclusion { margin-top: 40px; background-color: #E8F6F3; padding: 20px; border-radius: 8px; border: 1px solid #A3E4D7; }\n        .footer { margin-top: 50px; text-align: center; font-size: 12px; color: #BDC3C7; }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Apunte: ${data.titulo}</h1>\n        <div style=\"color: #7F8C8D; margin-top: 5px;\">Generado mediante Inteligencia Artificial</div>\n    </div>\n    <div class=\"intro\">${data.introduccion}</div>\n    <h2>Conceptos Clave</h2>\n`;\n\ndata.puntos_clave.forEach(punto => {\n    html += `\n    <div class=\"punto\">\n        <div class=\"subtitulo\">🔹 ${punto.subtitulo}</div>\n        <div class=\"explicacion\">${punto.explicacion}</div>\n    </div>`;\n});\n\nhtml += `\n    <div class=\"conclusion\">\n        <strong>Conclusión:</strong><br>${data.conclusion}\n    </div>\n    <div class=\"footer\">Documento de investigación generado para estudio personal.</div>\n</body>\n</html>`;\n\nreturn { html_content: html };"
      },
